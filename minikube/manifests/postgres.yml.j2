apiVersion: v1
kind: Secret
metadata:
  name: kong-db-auth
  namespace: {{ minikube_namespace }}
type: Opaque
stringData:
  postgres-password: "{{ kong_postgres_password }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ minikube_postgres_pvc_name }}
  namespace: {{ minikube_namespace }}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ minikube_postgres_storage_size }}
{% if minikube_storage_class_name %}
  storageClassName: {{ minikube_storage_class_name }}
{% endif %}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ kong_postgres_service_name }}
  namespace: {{ minikube_namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: {{ kong_postgres_service_name }}
  template:
    metadata:
      labels:
        app: {{ kong_postgres_service_name }}
    spec:
      containers:
        - name: postgres
          image: {{ kong_postgres_image }}
          env:
            - name: POSTGRES_DB
              value: "{{ kong_postgres_database }}"
            - name: POSTGRES_USER
              value: "{{ kong_postgres_user }}"
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: kong-db-auth
                  key: postgres-password
          ports:
            - containerPort: 5432
              name: postgres
          readinessProbe:
            exec:
              command: ["pg_isready", "-U", "{{ kong_postgres_user }}", "-d", "{{ kong_postgres_database }}"]
            initialDelaySeconds: 10
            periodSeconds: 10
          livenessProbe:
            exec:
              command: ["pg_isready", "-U", "{{ kong_postgres_user }}", "-d", "{{ kong_postgres_database }}"]
            initialDelaySeconds: 20
            periodSeconds: 15
          resources:
            requests:
              cpu: {{ minikube_postgres_cpu_request }}
              memory: {{ minikube_postgres_memory_request }}
            limits:
              cpu: {{ minikube_postgres_cpu_limit }}
              memory: {{ minikube_postgres_memory_limit }}
          volumeMounts:
            - name: postgres-storage
              mountPath: /var/lib/postgresql/data
      volumes:
        - name: postgres-storage
          persistentVolumeClaim:
            claimName: {{ minikube_postgres_pvc_name }}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ kong_postgres_service_name }}
  namespace: {{ minikube_namespace }}
spec:
  selector:
    app: {{ kong_postgres_service_name }}
  ports:
    - name: postgres
      port: 5432
      targetPort: postgres
