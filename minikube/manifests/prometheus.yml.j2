apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ minikube_prometheus_pvc_name }}
  namespace: {{ minikube_namespace }}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ minikube_prometheus_storage_size }}
{% if minikube_storage_class_name %}
  storageClassName: {{ minikube_storage_class_name }}
{% endif %}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: prometheus
  namespace: {{ minikube_namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: prometheus
  template:
    metadata:
      labels:
        app: prometheus
    spec:
      containers:
        - name: prometheus
          image: {{ observability_prometheus_image }}
          args:
            - --config.file=/etc/prometheus/prometheus.yml
            - --storage.tsdb.path=/prometheus
          ports:
            - containerPort: 9090
              name: http
          resources:
            requests:
              cpu: {{ minikube_prometheus_cpu_request }}
              memory: {{ minikube_prometheus_memory_request }}
            limits:
              cpu: {{ minikube_prometheus_cpu_limit }}
              memory: {{ minikube_prometheus_memory_limit }}
          volumeMounts:
            - name: prometheus-config
              mountPath: /etc/prometheus
              readOnly: true
            - name: prometheus-storage
              mountPath: /prometheus
      volumes:
        - name: prometheus-config
          configMap:
            name: prometheus-config
            items:
              - key: prometheus.yml
                path: prometheus.yml
              - key: kong-alerts.yml
                path: rules/kong-alerts.yml
              - key: kong-recording-rules.yml
                path: rules/kong-recording-rules.yml
        - name: prometheus-storage
          persistentVolumeClaim:
            claimName: {{ minikube_prometheus_pvc_name }}
---
apiVersion: v1
kind: Service
metadata:
  name: prometheus
  namespace: {{ minikube_namespace }}
spec:
  type: NodePort
  selector:
    app: prometheus
  ports:
    - name: http
      port: 9090
      targetPort: http
      nodePort: {{ minikube_prometheus_nodeport }}
