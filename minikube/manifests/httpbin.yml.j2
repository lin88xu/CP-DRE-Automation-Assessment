apiVersion: apps/v1
kind: Deployment
metadata:
  name: httpbin
  namespace: {{ minikube_namespace }}
spec:
  replicas: {{ minikube_httpbin_replicas }}
  selector:
    matchLabels:
      app: httpbin
  template:
    metadata:
      labels:
        app: httpbin
    spec:
      containers:
        - name: httpbin
          image: kennethreitz/httpbin
          ports:
            - containerPort: 80
              name: http
---
apiVersion: v1
kind: Service
metadata:
  name: httpbin
  namespace: {{ minikube_namespace }}
spec:
  selector:
    app: httpbin
  ports:
    - name: http
      port: 80
      targetPort: 80
