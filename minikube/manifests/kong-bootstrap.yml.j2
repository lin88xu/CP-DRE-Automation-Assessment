apiVersion: batch/v1
kind: Job
metadata:
  name: kong-bootstrap
  namespace: {{ minikube_namespace }}
spec:
  backoffLimit: 3
  ttlSecondsAfterFinished: 300
  template:
    metadata:
      labels:
        app: kong-bootstrap
    spec:
      restartPolicy: OnFailure
      containers:
        - name: bootstrap
          image: {{ kong_image }}
          imagePullPolicy: IfNotPresent
          command:
            - /bin/sh
            - -ec
            - |
              if ! kong migrations bootstrap; then
                kong migrations up -y || true
                kong migrations finish -y || true
              fi
              kong config db_import /etc/kong/declarative/kong.yml
          env:
            - name: KONG_DATABASE
              value: postgres
            - name: KONG_PG_HOST
              value: {{ kong_postgres_service_name }}
            - name: KONG_PG_PORT
              value: "{{ kong_db_port }}"
            - name: KONG_PG_USER
              value: "{{ kong_postgres_user }}"
            - name: KONG_PG_DATABASE
              value: "{{ kong_postgres_database }}"
            - name: KONG_PG_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: kong-db-auth
                  key: postgres-password
            - name: KONG_LOG_LEVEL
              value: info
          volumeMounts:
            - name: kong-config
              mountPath: /etc/kong/declarative
              readOnly: true
      volumes:
        - name: kong-config
          configMap:
            name: kong-config
