apiVersion: v1
kind: ConfigMap
metadata:
  name: prometheus-config
  namespace: {{ minikube_namespace }}
data:
  prometheus.yml: |
    global:
      scrape_interval: 10s
      evaluation_interval: 10s

    rule_files:
      - /etc/prometheus/rules/*.yml

    scrape_configs:
      - job_name: prometheus
        static_configs:
          - targets:
              - localhost:9090

      - job_name: {{ observability_kong_job_name }}
        metrics_path: /metrics
        static_configs:
          - targets:
              - kong.{{ minikube_namespace }}.svc.cluster.local:8001
            labels:
              environment: minikube
              scrape_target: kong
  kong-alerts.yml: |
{{ lookup('file', playbook_dir ~ '/../../promethusGrafana/prometheus/rules/kong-alerts.yml') | indent(4, true) }}
  kong-recording-rules.yml: |
{{ lookup('file', playbook_dir ~ '/../../promethusGrafana/prometheus/rules/kong-recording-rules.yml') | indent(4, true) }}
