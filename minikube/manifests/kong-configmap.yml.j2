apiVersion: v1
kind: ConfigMap
metadata:
  name: kong-config
  namespace: {{ minikube_namespace }}
data:
  kong.yml: |
    _format_version: "3.0"
    _transform: true

    services:
      - name: sample-service
        url: http://httpbin.{{ minikube_namespace }}.svc.cluster.local
        routes:
          - name: sample-route
            hosts:
              - {{ kong_app_host_header }}
            paths:
              - /
            methods:
              - GET
              - POST

    plugins:
      - name: cors
        config:
          origins:
            - "*"
          methods:
            - GET
            - POST
            - OPTIONS
          headers:
            - Accept
            - Authorization
            - Content-Type
            - Origin
          exposed_headers:
            - X-Auth-Token
          credentials: true
          max_age: 3600
      - name: prometheus
        config:
          per_consumer: true
          status_code_metrics: true
          latency_metrics: true
          bandwidth_metrics: true
          upstream_health_metrics: true
          ai_metrics: true
