global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/rules/*.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - localhost:9090

  - job_name: {{ observability_kong_job_name }}
    metrics_path: /metrics
    static_configs:
      - targets:
          - {{ observability_scrape_host }}:{{ observability_scrape_port }}
        labels:
          environment: managed
          scrape_target: kong
